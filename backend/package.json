{
  "name": "svaraverse-backend",
  "version": "1.0.0",
  "description": "SvaraVerse AI — Backend API Server",
  "main": "dist/server.js",
  "private": true,
  "scripts": {
    "dev":        "tsx watch src/server.ts",
    "build":      "tsc --project tsconfig.json",
    "start":      "node dist/server.js",
    "lint":       "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "db:migrate": "node -r tsx/cjs src/config/migrate.ts",
    "db:seed":    "node -r tsx/cjs src/config/seed.ts"
  },
  "dependencies": {
    "express":              "^4.19.2",
    "cors":                 "^2.8.5",
    "helmet":               "^7.1.0",
    "morgan":               "^1.10.0",
    "compression":          "^1.7.4",
    "dotenv":               "^16.4.5",

    "firebase-admin":       "^12.2.0",

    "openai":               "^4.52.7",

    "pg":                   "^8.12.0",
    "pg-pool":              "^3.6.2",

    "express-rate-limit":   "^7.3.1",
    "express-validator":    "^7.2.0",

    "jsonwebtoken":         "^9.0.2",
    "bcryptjs":             "^2.4.3",

    "razorpay":             "^2.9.5",

    "multer":               "^1.4.5-lts.1",
    "sharp":                "^0.33.4",

    "axios":                "^1.7.2",

    "uuid":                 "^10.0.0",
    "date-fns":             "^3.6.0",
    "zod":                  "^3.23.8",

    "winston":              "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",

    "node-cron":            "^3.0.3",

    "socket.io":            "^4.7.5",

    "@google-cloud/storage":"^7.12.0"
  },
  "devDependencies": {
    "typescript":           "^5.5.3",
    "@types/node":          "^20.14.11",
    "@types/express":       "^4.17.21",
    "@types/cors":          "^2.8.17",
    "@types/morgan":        "^1.9.9",
    "@types/compression":   "^1.7.5",
    "@types/pg":            "^8.11.6",
    "@types/jsonwebtoken":  "^9.0.6",
    "@types/bcryptjs":      "^2.4.6",
    "@types/multer":        "^1.4.11",
    "@types/uuid":          "^10.0.0",
    "tsx":                  "^4.16.2",
    "eslint":               "^8.57.0",
    "@typescript-eslint/parser":   "^7.16.1",
    "@typescript-eslint/eslint-plugin": "^7.16.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
